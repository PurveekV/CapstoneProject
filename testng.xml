
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Practo Cross Browser Suite" parallel="classes" thread-count="6">

    <listeners>
        <listener class-name="com.tests.practo.TestListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>

    </listeners>

    <test name="Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.tests.practo.HospitalFinder"/>
            <class name="com.tests.practo.DiagnosticPageTest"/>
            <class name="com.tests.practo.invalidDetailsTest"/>
        </classes>
    </test>

    <test name="Edge Tests">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.tests.practo.HospitalFinder"/>
            <class name="com.tests.practo.DiagnosticPageTest"/>
            <class name="com.tests.practo.invalidDetailsTest"/>
        </classes>
    </test>


</suite>